This mod improves the look of the vanilla HUD bar and adds a compass.

diff --git a/game.h b/game.h
index 8ab69b6..1b40d45 100644
--- a/game.h
+++ b/game.h
@@ -4336,6 +4336,19 @@ uint8_t SFG_drawNumber(
   return 5 - position;
 }
 
+uint8_t SFG_drawNumberWithShadow(
+  int16_t number,
+  uint16_t x,
+  uint16_t y,
+  uint8_t size,
+  uint8_t color,
+  uint8_t shadowSize,
+  uint8_t shadowColor)
+{
+  SFG_drawNumber(number,x + shadowSize,y + shadowSize,size,shadowColor);
+  return SFG_drawNumber(number,x,y,size,color);
+}
+
