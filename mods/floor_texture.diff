   for (uint16_t i = startIndex; i < camera.resolution.y; ++i)
     dest[i] = RCL_perspectiveScaleVerticalInverse(camHeightScreenSize,
-             RCL_abs(i - _RCL_middleRow));
+      RCL_abs(i - _RCL_middleRow));
 }
 
